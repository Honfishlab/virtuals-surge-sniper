# Base RPC (Base Mainnet)
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://mainnet.base.org

# Dune Analytics API key (optional - for rankings/macro data)
DUNE_API_KEY=

# ACP API authentication (required for full agent data)
ACP_AUTH_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# ACP config root (for acp-cli)
ACP_CONFIG_ROOT=/app/acp-configs

# Cache TTLs (seconds)
CACHE_TTL_TOKEN_LIST=30
CACHE_TTL_TOKEN_DETAIL=60
CACHE_TTL_SURGE_ALERTS=5
CACHE_TTL_DUNE=300

# Surge engine thresholds
SURGE_VOLUME_MULTIPLIER=2.0
SURGE_ACTIVITY_MULTIPLIER=1.5

# Alpha score weights (must sum to 1.0)
ALPHA_WEIGHT_SURGE=0.35
ALPHA_WEIGHT_USAGE=0.30
ALPHA_WEIGHT_BONDING=0.20
ALPHA_WEIGHT_TREND=0.15

# Snipe config
SNIPE_SIMULATION_MODE=true
