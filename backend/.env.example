# ===========================================
# Virtuals Surge Sniper - Environment Config
# ===========================================

# ── Base RPC ─────────────────────────────────────────────────
BASE_RPC_URL="https://mainnet.base.org"

# ── Virtuals Protocol Contracts on Base ──────────────────────
# Find these on basescan.org or Virtuals docs:
# Search for: VirtualsFactory, BondingV5, or Virtuals Protocol
# Example: FACTORY_ADDRESS="0x1234..."
FACTORY_ADDRESS=***
BONDING_V5_ADDRESS=***

# ── Dune Analytics ───────────────────────────────────────────
# Get API key at https://dune.com/settings/api
DUNE_API_KEY=*** ── ACP API (Virtuals Protocol) ─────────────────────────────
# Get token from Virtuals developer portal/docs
ACP_AUTH_TOKEN=*** ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Surge Engine Thresholds ──────────────────────────────────
SURGE_VOLUME_MULTIPLIER=2.0
SURGE_ACTIVITY_MULTIPLIER=1.5

# ── Alpha Score Weights ──────────────────────────────────────
ALPHA_WEIGHT_SURGE=0.35
ALPHA_WEIGHT_USAGE=0.30
ALPHA_WEIGHT_BONDING=0.20
ALPHA_WEIGHT_TREND=0.15

# ── Snipe Mode ───────────────────────────────────────────────
SNIPE_SIMULATION_MODE=true
